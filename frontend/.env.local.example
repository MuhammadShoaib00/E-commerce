# Same-origin: the browser calls /api and Next rewrites it to the backend
# (see next.config.ts), which keeps the httpOnly auth cookie same-site.
NEXT_PUBLIC_API_URL=/api
# Optional: where the Next rewrite proxy forwards /api (defaults to this).
BACKEND_ORIGIN=http://localhost:4001
# Stripe TEST-MODE publishable key (starts with pk_test_). Leave blank to use the
# mock payment flow. Pair it with the backend's STRIPE_SECRET_KEY.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
